# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Google Maps
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Prisma (pooled connection for app queries)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=30"

# Prisma (direct connection for migrations)
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?connect_timeout=30"
# Auth
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
AUTH_SECRET="YOUR_STRONG_AUTH_SECRET"
JWT_SECRET="YOUR_STRONG_JWT_SECRET"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
